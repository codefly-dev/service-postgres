resources:
  - namespace.yaml
  # In-cluster postgres (local-mode). For prod where the database is
  # managed externally (RDS, CloudNativePG operator, etc.), the
  # module-level overlay strips the per-service Application entirely
  # and adds an ExternalName Service instead.
  - stateful-set.yaml
  - service.yaml
{{- if .Deployment.Parameters.WithBootstrap }}
  # Database bootstrap runner: applies migrations when configured, then
  # reconciles the capability-scoped runtime roles on every deployment.
  - job.yaml
{{- end }}
